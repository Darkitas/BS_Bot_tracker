# Configuracion base del bot (sin valores reales)
BOT_NAME=tracker-bot
TIMEZONE=America/Bogota
LOG_LEVEL=info
RUNTIME_MODE=local
USE_PAIRING_CODE=false
PAIRING_PHONE_NUMBER=
WELCOME_ENABLED=true
WELCOME_GROUP_IDS=
WELCOME_TEMPLATE=Bienvenido/a a la comunidad.\n\nRellena esta ficha:\n- Nombre:\n- Edad:\n- ID del juego:
COMMAND_PREFIX=!
REPORT_COMMAND_KEYWORD=reporte
REPORT_DEFAULT_DAYS=60
REPORT_OUTPUT_DIR=reports
AUTH_DIR=auth
DB_PATH=data/tracker.db
